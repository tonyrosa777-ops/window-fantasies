# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — real secrets never get committed
.env*
# ...but the placeholder template MUST be, or the next person cannot know what
# the site needs. It contains no real values. The negation has to come AFTER the
# .env* line above; git evaluates last-match-wins.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# QA screenshots + agent artifacts (Audit Artifact Hygiene Rule — never committed)
/audits/
.playwright-mcp/
.optimus-review/

.vercel
