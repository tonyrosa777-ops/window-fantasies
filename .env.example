# Window Fantasies — environment variable template
#
# Copy to .env.local for local dev, and mirror every PRODUCTION value into
# Vercel > Project > Settings > Environment Variables.
#
#   cp .env.example .env.local
#
# .env.local is gitignored. This template is committed on purpose so the next
# person knows what the site needs. NEVER put a real key in this file.
#
# Every var below has a safe in-code fallback, which is why the site runs with
# none of them set — that is DEMO MODE, not production readiness. Read the
# "what breaks when blank" note on each one before assuming it is optional.


# ─────────────────────────────────────────────────────────────────────────────
# 1. RESEND — transactional email.  ⚠️ THE ONLY REVENUE-CRITICAL ONE.
# ─────────────────────────────────────────────────────────────────────────────
# 👉 VERIFY THIS SECTION WITH ONE COMMAND, from web/:
#
#      npm run verify:email                              # preflight only
#      npm run verify:email -- --to you@example.com      # + send both real templates
#      npm run verify:email -- --add-domain              # register domain, print DNS records
#
# It checks the key AND the sending-domain verification (two different things — see
# RESEND_DOMAIN below), then sends the ACTUAL templates so what you see in your inbox
# is what a customer gets. Exits non-zero while anything blocks.
# ─────────────────────────────────────────────────────────────────────────────
# Powers /api/contact (consultation + contact leads) and /api/review (the
# testimonials star survey). Server-side only — NEVER prefix with NEXT_PUBLIC_,
# that would ship the key to the browser.
#
# WHEN BLANK: both routes now return a LOUD 502 and the visitor is told delivery
# is not configured. They are NOT told "thanks, Jim will be in touch" while the
# lead is discarded — that silent-drop behaviour was removed 2026-07-20 per
# Error #205 (Anjo Services shipped it live and lost every lead). Seeded demo
# success now requires the explicit NEXT_PUBLIC_DEMO_MODE opt-in below.
#
# Get it: resend.com > API Keys > Create.
RESEND_API_KEY=

# Sending domain for the From: address (noreply@<this>). Must be a domain
# VERIFIED in Resend. Falls back to windowfantasies.com when blank.
#
# ⚠️ AS OF 2026-07-20 THIS DOMAIN IS NOT VERIFIED — the Resend account has ZERO
# domains registered, confirmed live against the API. Every send therefore fails:
#   403 "The windowfantasies.com domain is not verified"
# Verifying it means adding DKIM/SPF records at 007names, which is gated on
# runbook item O-1 (who holds that login). Until then, use RESEND_FROM below.
RESEND_DOMAIN=windowfantasies.com

# Full From: address override. Takes precedence over RESEND_DOMAIN.
#
# WHY IT EXISTS: it unblocks end-to-end email testing before the domain is
# verified. Resend's shared sender delivers with no domain setup:
#
#   RESEND_FROM="Window Fantasies <onboarding@resend.dev>"
#
# ⚠️ STOPGAP ONLY, never the ship state. The From line reads resend.dev instead
# of the brand, and a shared domain has weaker deliverability (Pattern #157).
# Once windowfantasies.com is verified in Resend, DELETE this line — the code
# falls back to the branded address on its own.
RESEND_FROM=

# Explicit demo-mode opt-in. Set to 1 ONLY for a keyless local demo.
#
# WHEN 1 (and not production): a blank RESEND_API_KEY returns a seeded success
# instead of a 502, so forms are clickable with no credentials.
# NEVER set this in Vercel production — it would re-create the silent-lead-loss
# bug the 502 exists to prevent (Error #205).
NEXT_PUBLIC_DEMO_MODE=


# ─────────────────────────────────────────────────────────────────────────────
# 2. SITE URL — canonicals, OG tags, sitemap, robots
# ─────────────────────────────────────────────────────────────────────────────
# No trailing slash. Falls back to https://www.windowfantasies.com when blank.
#
# WHEN BLANK IN PROD: canonicals + og:image resolve against the fallback apex.
# While the site is still on the vercel.app host and the custom domain is not
# connected, that fallback points at a domain that does not serve the site yet.
# Set this to the ACTUAL host the site is served from until DNS cuts over.
#
#   local dev  -> http://localhost:3000
#   pre-domain -> https://window-fantasies.vercel.app
#   post-domain-> https://www.windowfantasies.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ─────────────────────────────────────────────────────────────────────────────
# 3. GOOGLE ANALYTICS 4 — measurement
# ─────────────────────────────────────────────────────────────────────────────
# GA4 Measurement ID, format G-XXXXXXXXXX.
#
# WHEN BLANK: GoogleAnalytics.tsx renders nothing and no hits are sent. The
# component is also skipped entirely in development, and its init script is
# host-guarded to the production apex/www, so local + preview traffic can never
# pollute the property even once this is set.
#
# NOTE: GA4 is NOT part of the Pro website package. Analytics/conversion
# tracking sits in the separate Marketing & Growth menu. Leave blank unless Jim
# buys that, or Anthony provisions a property for his own reporting.
NEXT_PUBLIC_GA_ID=


# ─────────────────────────────────────────────────────────────────────────────
# 4. SANITY CMS — blog backend (OPTIONAL — see the note, this is a real decision)
# ─────────────────────────────────────────────────────────────────────────────
# WHEN BLANK: /blog renders the 10 articles from src/data/seededPosts.ts and
# /studio is disabled. The blog LOOKS complete and is fully SEO-indexed, because
# the articles are real and server-rendered. The difference is authorship:
#
#   blank      -> the 10 Pro articles ship as code. Jim CANNOT add or edit posts
#                 himself; a new article is a code change.
#   configured -> /studio becomes a real CMS Jim can log into and write in.
#
# The Pro tier promises "Professional Blog: 10 search-driven, source-cited
# articles" — it does NOT promise a CMS login. Seeded satisfies the sold scope.
# Provision Sanity only if Jim should self-author. DECIDE THIS WITH ANTHONY —
# do not provision by default, an unused Studio is a support surface.
#
# Get them: sanity.io/manage > project > API. Project ID is public/safe to expose.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01


# ─────────────────────────────────────────────────────────────────────────────
# NOT USED — do not add these
# ─────────────────────────────────────────────────────────────────────────────
# FAL_KEY                — fal.ai retired 2026-05-17 (Higgsfield MCP replaced it)
# CALENDLY_API_KEY       — no calendar on this build; booking is the on-domain
#                          Request-a-Consultation form (Resend). CLAUDE.md
#                          Client-Specific Deviation #3.
# STRIPE_* / PRINTFUL_*  — no shop on this build (Deviation #1)
